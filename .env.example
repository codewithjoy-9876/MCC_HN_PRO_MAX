# HN_PRO_MAX environment variables
# Used by Railway / Docker / local runs.

# Health endpoint port (Railway injects PORT automatically)
PORT=8080

# Comma-separated list of in-game owner usernames (case-insensitive)
OWNER_USERNAMES=.Nirankar66

# Optional bot username override (default HN_PRO_MAX)
BOT_USERNAME=HN_PRO_MAX

# Movement cadence (seconds between supervisor-driven actions)
MOVEMENT_INTERVAL=1.4

# Send throttle between commands going to MCC stdin (seconds)
SEND_THROTTLE=1.2

# Helps with logging in containers
PYTHONUNBUFFERED=1
